{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "bleed": true,
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "💰",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "SALDO MES",
                  "size": "Small",
                  "weight": "Bolder",
                  "color": "Accent",
                  "fontType": "Monospace"
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "R$ ${saldo}",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "color": "Accent",
                  "fontType": "Monospace",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${positivo ? 'UP' : 'DN'}",
                  "size": "Large",
                  "color": "Accent"
                }
              ]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${positivo ? 'positivo' : 'negativo'} este mes",
          "size": "Small",
          "color": "Light",
          "fontType": "Monospace",
          "spacing": "None"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}
