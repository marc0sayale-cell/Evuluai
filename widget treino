{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "${feito ? 'FEITO ✓' : 'HOJE'}",
          "size": "Small",
          "weight": "Bolder",
          "horizontalAlignment": "Center",
          "color": "Accent",
          "spacing": "Small"
        },
        {
          "type": "TextBlock",
          "text": "🏋️",
          "size": "ExtraLarge",
          "horizontalAlignment": "Center",
          "spacing": "None"
        },
        {
          "type": "TextBlock",
          "text": "${nome}",
          "size": "Large",
          "weight": "Bolder",
          "horizontalAlignment": "Center",
          "wrap": true,
          "spacing": "None"
        },
        {
          "type": "TextBlock",
          "text": "${duracao} min · ${exer} exercícios",
          "size": "Small",
          "horizontalAlignment": "Center",
          "color": "Light",
          "spacing": "None"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}
