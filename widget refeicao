{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "🍽️",
          "size": "ExtraLarge",
          "horizontalAlignment": "Center",
          "spacing": "Small"
        },
        {
          "type": "TextBlock",
          "text": "${nome}",
          "size": "Large",
          "weight": "Bolder",
          "horizontalAlignment": "Center",
          "wrap": true,
          "spacing": "None"
        },
        {
          "type": "ColumnSet",
          "horizontalAlignment": "Center",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [{"type": "TextBlock", "text": "P: ${prot}g", "size": "Small", "color": "Accent", "weight": "Bolder"}]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [{"type": "TextBlock", "text": "C: ${carbo}g", "size": "Small", "color": "Accent", "weight": "Bolder"}]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [{"type": "TextBlock", "text": "G: ${gord}g", "size": "Small", "color": "Accent", "weight": "Bolder"}]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${kcal} kcal",
          "size": "Large",
          "weight": "Bolder",
          "horizontalAlignment": "Center",
          "color": "Accent",
          "spacing": "None",
          "fontType": "Monospace"
        },
        {
          "type": "TextBlock",
          "text": "${tipo}",
          "size": "Small",
          "horizontalAlignment": "Center",
          "color": "Light",
          "spacing": "None"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}
